# Copy this file to .env.local and fill in your values.
# All variables must start with EXPO_PUBLIC_ to be accessible in the bundle.

# WalletConnect v2 project ID — get one free at https://cloud.walletconnect.com
EXPO_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id_here

# Flow network: 'testnet' or 'mainnet' (defaults to testnet if omitted)
EXPO_PUBLIC_FLOW_NETWORK=testnet
